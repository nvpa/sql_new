--cumulative spend customer per ,month
Select customer_id, month, sum(spend) Over Partition_by customer_id
order_by month)as cum_month
from monthly_spend

--gaps by sequential dates
select customer_id, month, spend,
lag(month) over (partition by customer_id order by month) as prev_month,   
lead(month) over (partition by customer_id order by month) as next_month
from monthly_spend

select lag(date) over (order by date) as prev_date,
date-lag(date) over (order by date) as gap
from events




--find and last transaction per user
select customer_id, transaction_date,
row_number() over (partition by customer_id order by transaction_date) as rn
from transactions
where rn = 1 --first transaction
or rn = 2 --last transaction
